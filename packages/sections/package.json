{
  "name": "@scope/sections",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hero-section": {
      "types": "./dist/hero-section.d.ts",
      "import": "./dist/hero-section.js"
    },
    "./feature-grid": {
      "types": "./dist/feature-grid.d.ts",
      "import": "./dist/feature-grid.js"
    },
    "./cta-section": {
      "types": "./dist/cta-section.d.ts",
      "import": "./dist/cta-section.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@scope/motion": "workspace:*",
    "@scope/react": "workspace:*",
    "@scope/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.15.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
