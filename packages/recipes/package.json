{
  "name": "@scope/recipes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./product-introduction": {
      "types": "./dist/product-introduction.d.ts",
      "import": "./dist/product-introduction.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@scope/motion": "workspace:*",
    "@scope/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.15.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
