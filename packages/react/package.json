{
  "name": "@scope/react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./animated-button": {
      "types": "./dist/animated-button.d.ts",
      "import": "./dist/animated-button.js"
    },
    "./pricing-card": {
      "types": "./dist/pricing-card.d.ts",
      "import": "./dist/pricing-card.js"
    },
    "./dialog": {
      "types": "./dist/dialog.d.ts",
      "import": "./dist/dialog.js"
    },
    "./sheet": {
      "types": "./dist/sheet.d.ts",
      "import": "./dist/sheet.js"
    },
    "./tooltip": {
      "types": "./dist/tooltip.d.ts",
      "import": "./dist/tooltip.js"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.js"
    },
    "./skeleton": {
      "types": "./dist/skeleton.d.ts",
      "import": "./dist/skeleton.js"
    },
    "./spotlight-card": {
      "types": "./dist/spotlight-card.d.ts",
      "import": "./dist/spotlight-card.js"
    },
    "./bento-grid": {
      "types": "./dist/bento-grid.d.ts",
      "import": "./dist/bento-grid.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "styles.css"],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@scope/motion": "workspace:*",
    "@scope/tokens": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3 <20",
    "react-dom": ">=18.3 <20"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsdown": "^0.15.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
